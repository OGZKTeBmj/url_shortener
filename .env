APP_NAME=auth-service
APP_VERSION=1.0.0
APP_ENV=local

LOG_LEVEL=debug

HTTP_PORT=8080
HTTP_SHUTDOWN_TIMEOUT=10s

POSTGRES_USER=root
POSTGRES_PASSWORD=admin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB_NAME=auth

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0
REDIS_REFRESH_TTL=15d